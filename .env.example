# Anthropic API — used for listing generation and (default) vision extraction
ANTHROPIC_API_KEY=

# Vision provider: claude-haiku | gemini-flash | grok-vision
VISION_PROVIDER=claude-haiku

# Google Sheets — for inventory/ROI tracking
GOOGLE_SHEETS_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json

# Vinted login — used by Playwright browser automation
VINTED_EMAIL=
VINTED_PASSWORD=

# Optional: Gemini API key (only needed if VISION_PROVIDER=gemini-flash)
GOOGLE_AI_API_KEY=
